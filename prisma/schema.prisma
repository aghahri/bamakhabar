generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  EDITOR
  REPORTER
}

model User {
  id             String       @id @default(cuid())
  username       String       @unique
  password       String
  name           String?
  role           UserRole     @default(REPORTER)
  approved       Boolean      @default(false)
  neighborhoodId String?
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  news           News[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  order     Int      @default(0)
  news      News[]   @relation("NewsCategories")
}

model Neighborhood {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  province        String?
  provinceSlug    String?
  city            String?
  citySlug        String?
  description     String?   // درباره این محله
  statusColor     String?   // green | yellow | red
  statusScore     Float?    // -1 to 1
  statusUpdatedAt DateTime?
  latitude        Float?    // آینده: مرکز تقریبی برای نقشه
  longitude       Float?
  news            News[]
  users           User[]
}

model NewsletterSubscription {
  id              String   @id @default(cuid())
  email           String   @unique
  neighborhoodIds String[] // id محلات برای دریافت خبرنامه
  createdAt       DateTime @default(now())
}

// --------------- Hyperlocal-ready: مدل‌ها برای توسعه آینده (شهر، منطقه، موضوع محلی، GIS، امتیاز مرتبط‌بودن) ---------------

enum IngestionStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

/// محتوای خام ورودی (قبل از تبدیل به خبر). آماده برای pipeline آینده و استخراج شهر/منطقه/محله.
model Ingestion {
  id                 String          @id @default(cuid())
  sourceUrl          String?         @unique
  sourceType         String?         // e.g. "rss", "scraper", "manual"
  rawTitle           String?
  rawBody            String?
  rawSummary         String?
  // استخراج شده از متن (برای تطبیق بعدی با city/district/neighborhood)
  extractedCity      String?
  extractedDistrict  String?
  extractedNeighborhoodName String?
  status             IngestionStatus @default(PENDING)
  processedNewsId    String?         @unique
  processedNews      News?           @relation(fields: [processedNewsId], references: [id], onDelete: SetNull)
  errorMessage       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

/// موضوعات محلی برای نگاشت بعدی به منطقه/شهر (بدون پیاده‌سازی نقشه؛ فقط مدل آماده).
model LocalTopic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  areaType  String?  // e.g. "city", "district", "neighborhood", "general"
  parentId  String?
  parent    LocalTopic?  @relation("LocalTopicHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  LocalTopic[] @relation("LocalTopicHierarchy")
  news      News[]   @relation("NewsLocalTopics")
}

model News {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  summary        String?
  body           String
  imageUrl       String?
  videoUrl       String?
  imageUrls     String[]     @default([])
  videoUrls     String[]     @default([])
  categories     Category[]   @relation("NewsCategories")
  neighborhoodId String?
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  createdById    String?
  createdBy      User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  published      Boolean      @default(false)
  featured       Boolean      @default(false)
  viewCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // --- Hyperlocal-ready (بدون استفاده اجباری؛ برای توسعه آینده) ---
  city               String?   // شهر (مثلاً وقتی محله مشخص نیست)
  district           String?   // منطقه/ناحیه
  latitude           Float?    // مختصات جغرافیایی (بدون نقشه الان)
  longitude          Float?
  localRelevanceScore Float?  // امتیاز مرتبط‌بودن محلی (۰–۱)
  localTopics        LocalTopic[] @relation("NewsLocalTopics")

  ingestion          Ingestion?
}
